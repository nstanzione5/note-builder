{
  "name": "note-builder",
  "version": "1.0.0",
  "description": "",
  "main": "app.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "med:compile": "node scripts/meds/compile-med-catalog.mjs",
    "med:sync": "node scripts/meds/sync-source-metadata.mjs",
    "med:sync:all": "node scripts/meds/sync-source-metadata.mjs --limit=260",
    "med:review": "node scripts/meds/build-review-report.mjs",
    "med:knowledge-check": "node scripts/meds/refresh-and-publish.mjs",
    "med:knowledge-check:local": "node scripts/meds/refresh-and-publish.mjs --skip-publish",
    "med:refresh-if-stale": "node scripts/meds/refresh-if-stale.mjs",
    "med:initial-sync": "node scripts/meds/refresh-and-publish.mjs",
    "med:initial-sync:local": "node scripts/meds/refresh-and-publish.mjs --skip-publish",
    "drive:bootstrap": "node scripts/drive/bootstrap-drive.mjs",
    "drive:bootstrap:full": "npm run drive:bootstrap && npm run med:initial-sync",
    "drive:audit-roots": "node scripts/drive/audit-root-folders.mjs",
    "drive:condense": "node scripts/drive/condense-mydrive.mjs",
    "drive:inspect": "node scripts/drive/inspect-drive.mjs",
    "drive:publish": "node scripts/drive/publish-to-drive.mjs",
    "drive:pull": "node scripts/drive/pull-from-drive.mjs",
    "drive:cleanup:dry-run": "node scripts/drive/condense-mydrive.mjs --root='Astra Clinical Note Builder' --max=1200",
    "drive:cleanup:apply": "node scripts/drive/condense-mydrive.mjs --apply --root='Astra Clinical Note Builder' --max=1200"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nstanzione5/note-builder.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/nstanzione5/note-builder/issues"
  },
  "homepage": "https://github.com/nstanzione5/note-builder#readme",
  "dependencies": {
    "jsdom": "^21.1.2"
  },
  "devDependencies": {
    "puppeteer": "^24.38.0"
  }
}
